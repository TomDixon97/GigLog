{
  "name": "tom/gig-log",
  "description": "A gig log API — learning PHP, Slim, Doctrine and Postgres",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "doctrine/orm": "^3.2",
    "doctrine/dbal": "^4.0",
    "doctrine/migrations": "^3.7",
    "symfony/cache": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}